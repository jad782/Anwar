{
  "name": "alanwar-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "تغليف تطبيق الأنوار كتطبيق أصلي (Android/iOS) عبر Capacitor",
  "scripts": {
    "copy:web": "node copy-web.js",
    "sync": "npm run copy:web && cap sync",
    "add:android": "npm run copy:web && cap add android",
    "add:ios": "npm run copy:web && cap add ios",
    "open:android": "cap open android",
    "open:ios": "cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/ios": "^6.1.2",
    "@capacitor/local-notifications": "^6.1.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^6.1.2",
    "sharp": "^0.35.1"
  }
}
